{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gct",
  "rules": {
    "source_file": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "element"
      }
    },
    "element": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "decleration"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        }
      ]
    },
    "decleration": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tag_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "composite_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "attribute_decleration"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "tag_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "tag"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "composite_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "composite"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "tag_reference"
              },
              {
                "type": "SYMBOL",
                "name": "attribute_reference"
              }
            ]
          }
        }
      ]
    },
    "tag_reference": {
      "type": "PATTERN",
      "value": "\\#[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "attribute_decleration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "attribute"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "type"
        }
      ]
    },
    "attribute_reference": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "value"
        }
      ]
    },
    "type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "number"
        },
        {
          "type": "STRING",
          "value": "percentage"
        },
        {
          "type": "STRING",
          "value": "text"
        },
        {
          "type": "STRING",
          "value": "date"
        },
        {
          "type": "STRING",
          "value": "time"
        },
        {
          "type": "STRING",
          "value": "datetime"
        }
      ]
    },
    "value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "datetime"
        },
        {
          "type": "SYMBOL",
          "name": "date"
        },
        {
          "type": "SYMBOL",
          "name": "time"
        },
        {
          "type": "SYMBOL",
          "name": "percentage"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "number": {
      "type": "PATTERN",
      "value": "[0-9]+(\\.[0-9]+)?"
    },
    "percentage": {
      "type": "PATTERN",
      "value": "[0-9]+(\\.[0-9]+)?%"
    },
    "text": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[a-zA-Z0-9_]+"
        },
        {
          "type": "PATTERN",
          "value": "\"[^\"]*\""
        }
      ]
    },
    "date": {
      "type": "PATTERN",
      "value": "[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "time": {
      "type": "PATTERN",
      "value": "[0-9]{2}:[0-9]{2}(:[0-9]{2})?"
    },
    "datetime": {
      "type": "PATTERN",
      "value": "[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}(:[0-9]{2})?"
    },
    "comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "line_comment"
        },
        {
          "type": "SYMBOL",
          "name": "block_comment"
        }
      ]
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "##?(?:[^#\\n][^\\n]*)?"
        }
      }
    },
    "block_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "###"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^#]+"
              },
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "#"
                  },
                  {
                    "type": "PATTERN",
                    "value": "[^#]"
                  }
                ]
              },
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "##"
                  },
                  {
                    "type": "PATTERN",
                    "value": "[^#]"
                  }
                ]
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "###"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}