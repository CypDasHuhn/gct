{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tree_sitter_gct",
      "camelcase": "TreeSitterGct",
      "title": "TreeSitterGct",
      "scope": "source.tree_sitter_gct",
      "file-types": [
        "gct"
      ],
      "injection-regex": "^tree_sitter_gct$",
      "class-name": "TreeSitterTreeSitterGct"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "The treesitter for GCT, General Composite Tags.",
    "authors": [
      {
        "name": "CypDasHuhn",
        "email": "Martinfischer533@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-tree_sitter_gct"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
